<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INT FORGE — NFT Card Studio</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

  :root {
    --void: #050508;
    --deep: #0a0a14;
    --surface: #0f0f1e;
    --panel: #141428;
    --border: #1e1e3f;
    --gold: #c9a227;
    --gold2: #ffd700;
    --cyan: #00e5ff;
    --magenta: #ff00cc;
    --purple: #9b00ff;
    --green: #00ff88;
    --red: #ff3355;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--void);
    color: #e8e8ff;
    font-family: 'Orbitron', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Starfield */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 60%, rgba(180,120,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 15%, rgba(0,229,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 75%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 50% 40%, rgba(255,200,0,0.3) 0%, transparent 100%),
      radial-gradient(2px 2px at 20% 80%, rgba(255,0,200,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 30%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 90%, rgba(0,255,136,0.3) 0%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 32px 20px 20px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(155,0,255,0.08) 0%, transparent 100%);
  }

  .logo {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(20px, 5vw, 42px);
    font-weight: 900;
    background: linear-gradient(90deg, var(--gold) 0%, var(--magenta) 40%, var(--cyan) 80%, var(--gold2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 4px;
    text-shadow: none;
    filter: drop-shadow(0 0 20px rgba(155,0,255,0.6));
  }

  .tagline {
    font-size: 10px;
    letter-spacing: 6px;
    color: rgba(0,229,255,0.6);
    margin-top: 6px;
    font-family: 'Share Tech Mono', monospace;
  }

  /* NAV TABS */
  .nav {
    display: flex;
    justify-content: center;
    gap: 4px;
    padding: 16px 20px;
    position: relative;
    z-index: 10;
    flex-wrap: wrap;
  }

  .nav-btn {
    background: var(--panel);
    border: 1px solid var(--border);
    color: rgba(200,200,255,0.5);
    padding: 8px 18px;
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.2s;
    clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
  }

  .nav-btn:hover, .nav-btn.active {
    background: linear-gradient(135deg, rgba(155,0,255,0.3), rgba(0,229,255,0.2));
    border-color: var(--cyan);
    color: var(--cyan);
    box-shadow: 0 0 12px rgba(0,229,255,0.3);
  }

  /* MAIN LAYOUT */
  .studio {
    display: grid;
    grid-template-columns: 280px 1fr 280px;
    gap: 0;
    min-height: calc(100vh - 160px);
    position: relative;
    z-index: 5;
  }

  @media (max-width: 1100px) {
    .studio { grid-template-columns: 1fr; }
    .sidebar-left, .sidebar-right { display: none; }
  }

  /* SIDEBARS */
  .sidebar-left, .sidebar-right {
    background: linear-gradient(180deg, var(--panel) 0%, var(--deep) 100%);
    border-right: 1px solid var(--border);
    padding: 20px 16px;
    overflow-y: auto;
    max-height: calc(100vh - 160px);
  }

  .sidebar-right { border-right: none; border-left: 1px solid var(--border); }

  .sidebar-section {
    margin-bottom: 24px;
  }

  .sidebar-label {
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--gold);
    border-bottom: 1px solid rgba(201,162,39,0.3);
    padding-bottom: 6px;
    margin-bottom: 12px;
  }

  .field-group { margin-bottom: 12px; }

  .field-label {
    font-size: 8px;
    letter-spacing: 2px;
    color: rgba(200,200,255,0.4);
    margin-bottom: 4px;
  }

  .field-input {
    width: 100%;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    color: #e8e8ff;
    padding: 8px 10px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    outline: none;
    transition: border-color 0.2s;
  }

  .field-input:focus { border-color: var(--cyan); box-shadow: 0 0 8px rgba(0,229,255,0.2); }

  .rarity-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .rarity-btn {
    padding: 5px 10px;
    font-size: 8px;
    letter-spacing: 1px;
    border: 1px solid;
    cursor: pointer;
    font-family: 'Orbitron', monospace;
    transition: all 0.2s;
    background: transparent;
  }

  .rarity-btn[data-r="COMMON"] { border-color: #666; color: #666; }
  .rarity-btn[data-r="UNCOMMON"] { border-color: #22c55e; color: #22c55e; }
  .rarity-btn[data-r="RARE"] { border-color: #3b82f6; color: #3b82f6; }
  .rarity-btn[data-r="LEGEND"] { border-color: #a855f7; color: #a855f7; }
  .rarity-btn[data-r="GENESIS"] { border-color: var(--gold); color: var(--gold); }
  .rarity-btn[data-r="MYTHIC"] { border-color: var(--magenta); color: var(--magenta); }

  .rarity-btn.active { filter: brightness(1.5); background: rgba(255,255,255,0.08); box-shadow: 0 0 10px currentColor; }

  .stat-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .stat-label { font-size: 9px; letter-spacing: 1px; color: rgba(200,200,255,0.5); width: 45px; }

  .stat-slider {
    flex: 1;
    -webkit-appearance: none;
    height: 3px;
    background: var(--border);
    outline: none;
    cursor: pointer;
  }

  .stat-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px; height: 12px;
    background: var(--cyan);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--cyan);
  }

  .stat-val { font-size: 11px; color: var(--cyan); width: 28px; text-align: right; font-family: 'Share Tech Mono', monospace; }

  /* FX GRID */
  .fx-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .fx-btn {
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    color: rgba(200,200,255,0.5);
    padding: 8px 6px;
    font-size: 8px;
    letter-spacing: 1px;
    cursor: pointer;
    font-family: 'Orbitron', monospace;
    transition: all 0.2s;
    text-align: center;
  }

  .fx-btn:hover, .fx-btn.active {
    border-color: var(--purple);
    color: var(--purple);
    box-shadow: 0 0 8px rgba(155,0,255,0.4);
    background: rgba(155,0,255,0.1);
  }

  /* CENTER STAGE */
  .stage {
    background: radial-gradient(ellipse at center, rgba(155,0,255,0.05) 0%, transparent 70%);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 20px;
    gap: 24px;
  }

  /* DECK STRIP */
  .deck-strip {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding: 12px 0;
    width: 100%;
    scrollbar-width: thin;
    scrollbar-color: var(--purple) transparent;
  }

  .deck-thumb {
    flex-shrink: 0;
    width: 80px;
    height: 110px;
    border: 2px solid var(--border);
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }

  .deck-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .deck-thumb::after {
    content: attr(data-name);
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(0,0,0,0.85);
    font-size: 6px;
    letter-spacing: 1px;
    padding: 3px;
    text-align: center;
    color: var(--gold);
    font-family: 'Orbitron', monospace;
  }

  .deck-thumb:hover, .deck-thumb.selected {
    border-color: var(--cyan);
    box-shadow: 0 0 16px rgba(0,229,255,0.5);
    transform: translateY(-4px);
  }

  /* MAIN CARD */
  .card-stage {
    position: relative;
    perspective: 1200px;
  }

  .card-wrapper {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.1s ease;
  }

  .nft-card {
    width: 340px;
    background: var(--deep);
    border: 2px solid var(--border);
    position: relative;
    overflow: hidden;
    box-shadow:
      0 0 40px rgba(155,0,255,0.3),
      0 0 80px rgba(155,0,255,0.1),
      inset 0 0 60px rgba(0,0,0,0.5);
  }

  .card-frame-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--frame-color, #9b00ff), var(--glow-color, #ff00cc), var(--frame-color, #9b00ff), transparent);
  }

  .card-frame-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--frame-color, #9b00ff), var(--glow-color, #ff00cc), var(--frame-color, #9b00ff), transparent);
  }

  /* Corner ornaments */
  .card-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    border-color: var(--frame-color, #9b00ff);
    border-style: solid;
    opacity: 0.8;
  }

  .card-corner.tl { top: 6px; left: 6px; border-width: 2px 0 0 2px; }
  .card-corner.tr { top: 6px; right: 6px; border-width: 2px 2px 0 0; }
  .card-corner.bl { bottom: 6px; left: 6px; border-width: 0 0 2px 2px; }
  .card-corner.br { bottom: 6px; right: 6px; border-width: 0 2px 2px 0; }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px 6px;
    position: relative;
  }

  .card-id-badge {
    font-size: 8px;
    letter-spacing: 2px;
    color: rgba(200,200,255,0.4);
    font-family: 'Share Tech Mono', monospace;
  }

  .rarity-badge {
    font-size: 8px;
    letter-spacing: 2px;
    padding: 3px 8px;
    border: 1px solid;
    font-family: 'Orbitron', monospace;
    font-weight: 700;
  }

  .card-art {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
  }

  .card-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .card-art-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 80px;
    background: linear-gradient(0deg, var(--deep) 0%, transparent 100%);
  }

  .element-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0,0,0,0.7);
    border: 1px solid;
    padding: 4px 8px;
    font-size: 8px;
    letter-spacing: 2px;
    font-family: 'Share Tech Mono', monospace;
  }

  .card-name-block {
    padding: 8px 14px 4px;
  }

  .card-name {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(14px, 4vw, 18px);
    font-weight: 700;
    letter-spacing: 2px;
    line-height: 1.1;
    color: #fff;
    text-shadow: 0 0 20px var(--glow-color, #ff00cc);
  }

  .card-subtitle {
    font-size: 9px;
    letter-spacing: 2px;
    opacity: 0.6;
    margin-top: 2px;
    font-family: 'Share Tech Mono', monospace;
  }

  .stats-bar {
    display: flex;
    gap: 0;
    padding: 10px 14px;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .stat-cell {
    flex: 1;
    text-align: center;
  }

  .stat-num {
    font-size: 20px;
    font-weight: 900;
    color: #fff;
    font-family: 'Orbitron', monospace;
    line-height: 1;
  }

  .stat-name {
    font-size: 7px;
    letter-spacing: 2px;
    color: rgba(200,200,255,0.4);
    margin-top: 2px;
  }

  .ability-block {
    padding: 10px 14px;
    background: rgba(0,0,0,0.2);
  }

  .ability-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .ability-icon {
    width: 14px;
    height: 14px;
    border: 1px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    color: var(--gold);
    flex-shrink: 0;
  }

  .ability-name {
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--gold);
    font-weight: 700;
  }

  .ability-desc {
    font-size: 9px;
    line-height: 1.6;
    color: rgba(200,200,255,0.6);
    font-family: 'Share Tech Mono', monospace;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 14px 12px;
  }

  .value-label { font-size: 8px; letter-spacing: 1px; color: rgba(200,200,255,0.4); }
  .value-amount { font-size: 16px; font-weight: 900; color: var(--gold); font-family: 'Orbitron', monospace; }
  .pool-label { font-size: 8px; text-align: right; color: rgba(200,200,255,0.4); }

  /* SCANLINE FX */
  .card-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 5;
  }

  /* GLITCH FX */
  @keyframes glitch {
    0%, 90%, 100% { clip-path: none; transform: translate(0); }
    92% { clip-path: polygon(0 20%, 100% 20%, 100% 30%, 0 30%); transform: translate(-4px, 0); }
    94% { clip-path: polygon(0 60%, 100% 60%, 100% 70%, 0 70%); transform: translate(4px, 0); }
    96% { clip-path: polygon(0 40%, 100% 40%, 100% 50%, 0 50%); transform: translate(-2px, 0); }
    98% { clip-path: none; transform: translate(0); }
  }

  .card-wrapper.fx-glitch .nft-card {
    animation: glitch 4s infinite;
  }

  @keyframes scanbeam {
    0% { top: -10%; }
    100% { top: 110%; }
  }

  .scanbeam-el {
    position: absolute;
    left: 0; right: 0;
    height: 40px;
    background: linear-gradient(180deg, transparent, rgba(0,229,255,0.1), transparent);
    pointer-events: none;
    z-index: 6;
    display: none;
    top: -10%;
  }

  .card-wrapper.fx-scanbeam .scanbeam-el {
    display: block;
    animation: scanbeam 2s linear infinite;
  }

  @keyframes lensflare {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.7; }
  }

  .lensflare-el {
    position: absolute;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,200,0.8) 0%, transparent 70%);
    top: 30%; left: 30%;
    transform: translate(-50%,-50%);
    pointer-events: none;
    z-index: 7;
    display: none;
    mix-blend-mode: screen;
  }

  .card-wrapper.fx-lensflare .lensflare-el {
    display: block;
    animation: lensflare 3s ease-in-out infinite;
  }

  @keyframes particles {
    0% { transform: translateY(0) translateX(0) scale(1); opacity: 1; }
    100% { transform: translateY(-60px) translateX(var(--dx, 20px)) scale(0); opacity: 0; }
  }

  .particle { position: absolute; width: 4px; height: 4px; border-radius: 50%; background: var(--cyan); pointer-events: none; z-index: 8; }

  @keyframes circuits {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.6; }
  }

  .circuits-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    pointer-events: none;
    z-index: 4;
    display: none;
    animation: circuits 2s ease-in-out infinite;
  }

  .card-wrapper.fx-circuits .circuits-overlay { display: block; }

  /* RAIN FX */
  @keyframes rain {
    0% { transform: translateY(-100%); opacity: 0.6; }
    100% { transform: translateY(100vh); opacity: 0; }
  }

  /* VIGNETTE */
  .vignette-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
    z-index: 3;
    display: none;
  }

  .card-wrapper.fx-vignette .vignette-overlay { display: block; }

  /* ACTION BUTTONS */
  .action-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .action-btn {
    padding: 12px 24px;
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid;
    transition: all 0.25s;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    position: relative;
    overflow: hidden;
  }

  .btn-mint {
    background: linear-gradient(135deg, rgba(0,229,255,0.2), rgba(155,0,255,0.2));
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .btn-mint:hover {
    background: linear-gradient(135deg, rgba(0,229,255,0.4), rgba(155,0,255,0.4));
    box-shadow: 0 0 30px rgba(0,229,255,0.5);
    transform: translateY(-2px);
  }

  .btn-save {
    background: rgba(201,162,39,0.1);
    border-color: var(--gold);
    color: var(--gold);
  }

  .btn-save:hover {
    background: rgba(201,162,39,0.25);
    box-shadow: 0 0 20px rgba(201,162,39,0.4);
  }

  .btn-random {
    background: rgba(255,0,204,0.1);
    border-color: var(--magenta);
    color: var(--magenta);
  }

  .btn-random:hover {
    background: rgba(255,0,204,0.25);
    box-shadow: 0 0 20px rgba(255,0,204,0.4);
  }

  .btn-export {
    background: rgba(0,255,136,0.1);
    border-color: var(--green);
    color: var(--green);
  }

  .btn-export:hover {
    background: rgba(0,255,136,0.25);
    box-shadow: 0 0 20px rgba(0,255,136,0.4);
  }

  /* MINT MODAL */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--panel);
    border: 1px solid var(--cyan);
    box-shadow: 0 0 60px rgba(0,229,255,0.3);
    padding: 32px;
    width: 90%;
    max-width: 500px;
    position: relative;
  }

  .modal-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: 20px;
    color: var(--cyan);
    margin-bottom: 20px;
    text-align: center;
    text-shadow: 0 0 20px var(--cyan);
  }

  .mint-field {
    margin-bottom: 16px;
  }

  .mint-field label {
    display: block;
    font-size: 9px;
    letter-spacing: 2px;
    color: rgba(200,200,255,0.5);
    margin-bottom: 6px;
  }

  .mint-field input, .mint-field select, .mint-field textarea {
    width: 100%;
    background: rgba(0,0,0,0.5);
    border: 1px solid var(--border);
    color: #e8e8ff;
    padding: 10px 12px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    outline: none;
  }

  .mint-field input:focus, .mint-field select:focus, .mint-field textarea:focus {
    border-color: var(--cyan);
  }

  .mint-field select { cursor: pointer; }

  .mint-field textarea { resize: vertical; min-height: 60px; }

  .mint-progress {
    height: 4px;
    background: var(--border);
    margin: 20px 0;
    overflow: hidden;
    display: none;
  }

  .mint-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--purple), var(--cyan), var(--magenta));
    width: 0%;
    transition: width 0.3s;
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  .mint-status {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--cyan);
    text-align: center;
    min-height: 20px;
    margin-bottom: 16px;
  }

  .modal-actions { display: flex; gap: 10px; }

  .modal-btn {
    flex: 1;
    padding: 12px;
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    cursor: pointer;
    border: 1px solid;
    transition: all 0.2s;
    font-weight: 700;
  }

  .modal-btn-confirm {
    background: linear-gradient(135deg, rgba(0,229,255,0.2), rgba(155,0,255,0.2));
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .modal-btn-confirm:hover {
    background: linear-gradient(135deg, rgba(0,229,255,0.4), rgba(155,0,255,0.4));
    box-shadow: 0 0 20px rgba(0,229,255,0.4);
  }

  .modal-btn-cancel {
    background: rgba(255,51,85,0.1);
    border-color: var(--red);
    color: var(--red);
  }

  .modal-btn-cancel:hover {
    background: rgba(255,51,85,0.25);
  }

  /* MINTED GALLERY */
  .minted-section {
    padding: 20px;
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .minted-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: 14px;
    color: var(--gold);
    letter-spacing: 3px;
    margin-bottom: 16px;
    text-align: center;
  }

  .minted-grid {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .minted-card {
    width: 120px;
    background: var(--panel);
    border: 1px solid;
    padding: 8px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
  }

  .minted-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }

  .minted-card img {
    width: 100%;
    height: 80px;
    object-fit: cover;
    object-position: top;
    margin-bottom: 6px;
  }

  .minted-card-name { font-size: 7px; letter-spacing: 1px; color: var(--gold); margin-bottom: 2px; }
  .minted-card-id { font-size: 7px; color: rgba(200,200,255,0.4); font-family: 'Share Tech Mono', monospace; }
  .minted-card-rarity { font-size: 7px; letter-spacing: 1px; }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: var(--panel);
    border: 1px solid var(--cyan);
    padding: 14px 20px;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--cyan);
    box-shadow: 0 0 30px rgba(0,229,255,0.3);
    z-index: 2000;
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s;
    font-family: 'Share Tech Mono', monospace;
  }

  .toast.show { transform: translateY(0); opacity: 1; }

  /* 3D TILT INDICATOR */
  .tilt-hint {
    font-size: 8px;
    letter-spacing: 2px;
    color: rgba(200,200,255,0.3);
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
  }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: var(--void); }
  ::-webkit-scrollbar-thumb { background: var(--purple); }
</style>
